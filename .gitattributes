# ===========================================================================
# Git 行为规范：换行符 · 二进制识别 · 归档控制
# 适用于 Vue / React / Vite / TypeScript 等现代前端项目
# ===========================================================================

# 全局：自动识别文本，工作区统一使用 LF
* text=auto eol=lf

# ------------------------------------------------------------------------------
# 文本文件（确保可 diff 与格式化）
# ------------------------------------------------------------------------------
*.js      text eol=lf
*.ts      text eol=lf
*.jsx     text eol=lf
*.tsx     text eol=lf
*.vue     text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf

*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.toml    text eol=lf

*.env     text eol=lf
*.env.*   text eol=lf

*.css     text eol=lf
*.scss    text eol=lf
*.sass    text eol=lf
*.less    text eol=lf
*.styl    text eol=lf

*.html    text eol=lf
*.htm     text eol=lf
*.xml     text eol=lf
*.md      text eol=lf
*.markdown text eol=lf
*.svg     text eol=lf

# 配置文件（支持常见后缀）
*.{config,rc}.{js,ts,cjs,mjs,json,yaml,yml} text eol=lf

# ------------------------------------------------------------------------------
# 二进制资源（禁止换行转换和文本 diff）
# ------------------------------------------------------------------------------
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.avif    binary
*.bmp     binary
*.tiff    binary
*.eps     binary
*.svgz    binary

*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary

*.zip     binary
*.gz      binary
*.tar     binary
*.tgz     binary
*.pdf     binary

# ------------------------------------------------------------------------------
# 构建产物与缓存目录（禁用文本处理）
# ------------------------------------------------------------------------------
/dist/**        -text
/build/**       -text
/.vite/**       -text
/.nuxt/**       -text
/.output/**     -text
/.cache/**      -text
/.temp/**       -text
/node_modules/** -text
/public/build/** -text

# ------------------------------------------------------------------------------
# 归档（git archive）控制：排除开发文件
# ------------------------------------------------------------------------------
.eslintrc.{js,cjs}                  export-ignore
.prettierrc                         export-ignore
.prettierrc.{json,yaml,yml}         export-ignore
babel.config.js                     export-ignore
vite.config.{js,ts,mjs,cjs}         export-ignore
webpack.config.js                   export-ignore
rollup.config.js                    export-ignore
.editorconfig                       export-ignore
.gitattributes                      export-ignore
.gitignore                          export-ignore
.env.*                              export-ignore
README.md                           export-subst
